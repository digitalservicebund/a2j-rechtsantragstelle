  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build:airports-data": "node ./scripts/airports.ts",
    "build:airlines-data": "node ./scripts/airlines.ts",
    "build:app": "react-router build",
    "build:licenses": "node ./scripts/generateLicenseFile.ts",
    "build:localContent": "node ./scripts/vite-runner.ts dumpCmsToFile",
    "build:pdf": "node ./scripts/pdf.generator.ts",
    "build:storybook": "storybook build --output-dir ./build/client/storybook",
    "build:typesFromXSD": "pnpm @wikipathways/cxsd ./data/xml/schemas/xjustiz_3400_rast_0_1.xsd -t data/xml/generated",
    "build": "pnpm run build:app && pnpm run build:storybook",
    "dev": "node ./server.mjs",
    "format:fix": "prettier --write . --ignore-path .prettierignore",
    "format": "prettier --check . --ignore-path .prettierignore",
    "init": "lefthook install",
    "lint:fix": "oxlint --fix",
    "lint": "oxlint && knip --no-config-hints",
    "size": "react-router build --logLevel error && size-limit",
    "start:storybook": "storybook dev -p 6006",
    "start": "NODE_ENV=production node ./server.mjs",
    "test:coverage": "vitest run --project=!integration --coverage",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:e2e": "pnpm exec playwright test",
    "test": "vitest run --project=!integration",
    "test:watch": "vitest --project=!integration",
    "test:integration": "./tests/integration/runTests.sh",
    "typecheck": "react-router typegen && tsc",
    "typecheck:watch": "react-router typegen && tsc -w",
    "update:courtData": "node ./scripts/vite-runner.ts courtDataUpdate",
    "update:courtDataKey": "node ./scripts/vite-runner.ts courtDataRotateKey",
    "update:courtURLs": "node ./scripts/vite-runner.ts checkCourtURLs",
    "update:streetNames": "node ./scripts/vite-runner.ts updateStreetNames",
    "verify:emails": "node ./scripts/verifyExternalLinks.ts verifyEmails",
    "verify:unusedStrapiEntries": "node ./scripts/vite-runner.ts unusedStrapiEntry",
    "verify:websites": "node ./scripts/verifyExternalLinks.ts verifyWebsites"
  },
